{
  "name": "warhammer-api",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/makeconstnotvar/warhammer-api#readme",
  "bugs": {
    "url": "https://github.com/makeconstnotvar/warhammer-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makeconstnotvar/warhammer-api.git"
  },
  "exports": {
    "./package.json": "./package.json",
    "./sdk": {
      "types": "./sdk/warhammerApiV1Client.d.ts",
      "import": "./sdk/warhammerApiV1Client.mjs"
    },
    "./sdk/module": "./sdk/warhammerApiV1Client.mjs",
    "./sdk/types": "./sdk/warhammerApiV1Client.d.ts"
  },
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "scripts": {
    "server": "node server/index.js",
    "server-watch": "nodemon server/index.js",
    "client-watch": "webpack --watch --config client/webpack.config.js",
    "build-dev": "webpack --config client/webpack.config.js",
    "lint": "eslint . --ext .js,.jsx --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sdk:generate": "node scripts/generateSdk.js",
    "sdk:check": "node scripts/generateSdk.js --check",
    "test": "node tests/runApiTests.js",
    "verify": "npm run lint && npm run format:check && npm run sdk:check && npm run build-dev && npm test",
    "db:migrate": "node db/scripts/runMigrations.js",
    "db:seed": "node db/seeds/seedLearningData.js",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bootstrap": "^5.3.5",
    "cors": "^2.8.5",
    "css-loader": "^7.1.2",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.14.1",
    "preact-iso": "^2.9.1",
    "preact-render-to-string": "^6.6.6",
    "query-core": "^0.2.2",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "swagger-ui-dist": "^5.17.14"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@eslint/js": "^9.39.4",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.6.3",
    "mobx": "^6.13.7",
    "mobx-react": "^9.2.0",
    "nodemon": "^3.1.9",
    "preact": "^10.26.4",
    "prettier": "^3.8.1",
    "style-loader": "^4.0.0",
    "webpack": "^5.105.4",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  }
}
